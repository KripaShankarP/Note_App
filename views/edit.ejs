<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
    <title>Document</title>
  </head>
  <body>
    <div class="w-full min-h-screen bg-zinc-900 text-white pl-20 pt-3">
      
      <h3>edit your post</h3>

      <form action="/update/<%=post._id%>" method="post">
        <textarea
          id=""
          placeholder=""
          name="content"
          class="w-1/3 border-1 border-white pl-2 mt-3 flex flex-col outline-none"
        ><%= post.content%></textarea>
        <input
          type="submit"
          value="update post"
          class="bg-blue-500 w-30 text-white rounded-xl p-.5 mt-3"
        />
      </form>
    </div>
  </body>
</html>
