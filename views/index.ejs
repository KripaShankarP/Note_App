<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
    <title>Document</title>
</head>
<body>
   <div class="w-full min-h-screen bg-zinc-900 text-white pl-20 pt-3">
    <h1 class="mb-10 ml-20"> Create New User</h1>
    <form action="/register" method="post" class="flex flex-col gap-3">
        <input type="text" placeholder="username" name="username" class="w-1/4 bg-zinc-800 rounded-md outline-none text-xl h-9 p-2">
        <input type="number" placeholder="age" name="age" class="w-1/4 bg-zinc-800 rounded-md outline-none text-xl h-9 p-2">
        <input type="email" placeholder="email" name="email" class="w-1/4 bg-zinc-800 rounded-md outline-none text-xl h-9 p-2">
        <input type="password" placeholder="password" name="password" class="w-1/4 bg-zinc-800 rounded-md outline-none text-xl h-9 p-2">
        <input type="submit" value="Create User" class="w-20 bg-blue-500 p-0.5 rounded-md hover:bg-blue-600">
    </form>

   </div> 
</body>
</html>