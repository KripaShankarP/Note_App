<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
    <title>Document</title>
  </head>
  <body>
    <div class="w-full min-h-screen bg-zinc-900 text-white pl-20 pt-3">
      <h1 class="mb-1 ml-20 text-xl">Hello , <%= user.username %></h1>
      <h3>you can create a new post</h3>
      <div class="flex justify-end">
        <a href="/logout" class="bg-red-500 w-20 text-white rounded-md pl-3"
          >Log out</a
        >
      </div>
      <form action="/post" method="post">
        <textarea
          id=""
          placeholder="Create a post"
          name="content"
          class="w-1/3 border-1 border-white pl-2 mt-3 flex flex-col outline-none"
        ></textarea>
        <input
          type="submit"
          value="Create post"
          class="bg-blue-500 w-30 text-white rounded-xl p-.5 mt-3"
        />
      </form>
      <div class="posts mt-10">
        <h1 class="text-xl">Your All Posts</h1>
        <div class="flex gap-2 ">
          <% user.posts.forEach((post)=>{%>
          <div class="w-1/4 border-2 border-zinc-800 p-3 mt-3 bg-zinc-800 rounded-md">
            <h4 class="text-blue-500">@<%=user.username%></h4>
            <p><%=post.content%></p>
            <small><%= post.likes.length%> Likes </small>
            <div class="mt-5 flex justify-between">
              <a href="/like/<%=post._id%>" class="bg-blue-600 w-15 rounded-md text-center"
                ><%=
              post.likes.indexOf(user._id)=== -1 ? 'Like' : "Unlike"
              %></a
              >
              <a href="/edit/<%=post._id%>">edit</a>
              <a href="/delete/<%=post._id%>" class="text-red-500">Delete</a>
              
            </div>
          </div>
          <%})%>
        </div>
      </div>
    </div>
  </body>
</html>
